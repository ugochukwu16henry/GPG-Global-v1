generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PathwayStatus {
  CONNECT
  DEGREE
  ALUMNI
}

enum RelationshipStatus {
  SINGLE
  MARRIED
}

enum Gender {
  MALE
  FEMALE
}

enum VisibilityLevel {
  EVERYONE
  CONNECTIONS
  ONLY_ME
}

enum ProfessionalStatus {
  DRAFT
  LIVE_PROFESSIONAL
  MERIT_GRANTED
}

enum SensitiveField {
  GENOTYPE
  BLOOD_GROUP
}

enum ChatViolationSeverity {
  LOW
  MEDIUM
  HIGH
}

enum MarketplaceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  MERIT_GRANTED
}

enum AdReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BlockReasonCode {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  OTHER
}

enum ReportReasonCode {
  SPAM
  HARASSMENT
  SCAM
  INAPPROPRIATE_CONTENT
  OTHER
}

enum GatheringLevel {
  GLOBAL
  LOCAL
  SUB_GROUP
}

enum GroupMembershipRole {
  MEMBER
  FRIEND
  SEEKER
  MODERATOR
  LEADER
}

enum GroupCategory {
  GENERAL
  SELF_RELIANCE
  TEMPLE_PREP
  SOCIAL
}

enum FaithConductCategory {
  DISRESPECTFUL_LANGUAGE
  IMMODEST_INAPPROPRIATE_CONTENT
  DISHONEST_CONDUCT
  UNWHOLESOME_BEHAVIOR
}

enum BreakGlassTrigger {
  HIGH_RISK_AI_ALERT
  USER_REPORT
}

enum BreakGlassResolutionAction {
  PENDING
  DISMISSED
  WARNING_SENT
  SUSPENDED_7_DAYS
  PERMANENT_BAN
}

model User {
  id                 String               @id @default(cuid())
  phone              String               @unique
  displayName        String
  profilePictureUrl  String?
  bio                String?
  country            String?
  isMember           Boolean              @default(false)
  missionId          String?
  mission            Mission?             @relation(fields: [missionId], references: [id])
  servedMission      Boolean              @default(false)
  birthday           DateTime?
  relationshipStatus RelationshipStatus?
  gender             Gender?
  pathwayStatus      PathwayStatus        @default(CONNECT)
  isPathwayConnect   Boolean              @default(true)
  isDegree           Boolean              @default(false)
  isAlumni           Boolean              @default(false)
  academicFocus      String?
  lga                String?
  state              String?
  genotypeCiphertext String?
  bloodGroupCiphertext String?
  allowsBirthdayBroadcast Boolean         @default(false)
  safeSearchFemaleOnly Boolean            @default(false)
  safeSearchVerifiedMembersOnly Boolean   @default(false)
  professionalStatus ProfessionalStatus   @default(DRAFT)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  privacyGrantsOwned PrivacyGrant[]       @relation("OwnerGrants")
  privacyGrantsReceived PrivacyGrant[]    @relation("ViewerGrants")
  privacySettings    FieldVisibility[]
  paymentEvents      PaymentEvent[]
  chatMessages       ChatMessage[]
  authOtps           AuthOtp[]
  missionAlumni      MissionAlumni[]
  authoredPosts      Post[]
  postComments       PostComment[]
  postReactions      PostReaction[]
  postReshares       PostReshare[]
  disciplineState    UserDisciplineState?
  adminActions       AdminActionLog[] @relation("AdminActorActions")
  blockedUsers       BlockRelation[] @relation("Blocker")
  blockedByUsers     BlockRelation[] @relation("Blocked")
  mutedUsers         MuteRelation[] @relation("Muter")
  mutedByUsers       MuteRelation[] @relation("Muted")
  reportsSubmitted   UserReport[] @relation("Reporter")
  reportsReceived    UserReport[] @relation("Reported")
  groupMemberships   GatheringGroupMembership[]
  checkIns           GatheringCheckIn[]
  readReceipts       GroupMessageReadReceipt[]
  safetyFlags        SafetyMetadataFlag[]
  breakGlassBundlesReported BreakGlassReportBundle[] @relation("BundleReporter")
}

model Mission {
  id            String @id @default(cuid())
  missionCode   String @unique
  missionName   String @unique
  country       String
  city          String?
  region        String?
  createdAt     DateTime @default(now())

  users         User[]
  alumniRecords MissionAlumni[]
}

model AuthOtp {
  id            String @id @default(cuid())
  phone         String
  otpCodeHash   String
  expiresAt     DateTime
  verifiedAt    DateTime?
  userId        String?
  user          User? @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())

  @@index([phone, expiresAt])
}

model ModeratorInviteCode {
  id               String   @id @default(cuid())
  code             String   @unique
  gatheringPlace   String
  roleLabel        String
  createdByAdminId String
  isActive         Boolean  @default(true)
  consumedAt       DateTime?
  consumedByUserId String?
  createdAt        DateTime @default(now())

  @@index([gatheringPlace, createdAt])
  @@index([isActive, createdAt])
}

model PrivacyGrant {
  id             String @id @default(cuid())
  ownerUserId    String
  viewerUserId   String
  field          SensitiveField
  grantedAt      DateTime @default(now())
  revokedAt      DateTime?

  ownerUser      User @relation("OwnerGrants", fields: [ownerUserId], references: [id])
  viewerUser     User @relation("ViewerGrants", fields: [viewerUserId], references: [id])

  @@index([ownerUserId, viewerUserId, field])
}

model FieldVisibility {
  id             String @id @default(cuid())
  userId         String
  fieldKey       String
  visibility     VisibilityLevel @default(ONLY_ME)
  updatedAt      DateTime @updatedAt

  user           User @relation(fields: [userId], references: [id])

  @@unique([userId, fieldKey])
}

model MissionAlumni {
  id             String @id @default(cuid())
  userId         String
  missionId      String
  serviceYearFrom Int
  serviceYearTo   Int
  createdAt      DateTime @default(now())

  user           User @relation(fields: [userId], references: [id])
  mission        Mission @relation(fields: [missionId], references: [id])

  @@index([missionId, serviceYearFrom, serviceYearTo])
}

model PaymentEvent {
  id             String @id @default(cuid())
  userId         String
  provider       String
  amountUsd      Decimal @db.Decimal(10, 2)
  currency       String  @default("USD")
  externalRef    String  @unique
  status         String
  metadata       Json?
  createdAt      DateTime @default(now())

  user           User @relation(fields: [userId], references: [id])
}

model MeritOverride {
  id             String @id @default(cuid())
  userId         String @unique
  grantedByAdminId String
  reason         String
  createdAt      DateTime @default(now())
}

model ChatMessage {
  id             String @id @default(cuid())
  senderUserId   String
  roomId         String
  body           String
  threadId       String?
  isHiddenByAi   Boolean @default(false)
  createdAt      DateTime @default(now())

  senderUser     User @relation(fields: [senderUserId], references: [id])
  moderationFlag ModerationFlag?
  readReceipts   GroupMessageReadReceipt[]

  @@index([roomId, createdAt])
}

model Post {
  id             String @id @default(cuid())
  authorUserId   String
  textBody       String?
  mediaUrl       String?
  skillHighlight String?
  videoCodec     String?
  sourceResolution String?
  availableResolutions Json?
  captions       Json?
  moderationTags Json?
  isHiddenPendingReview Boolean @default(false)
  copyrightBlocked Boolean @default(false)
  createdAt      DateTime @default(now())

  author         User @relation(fields: [authorUserId], references: [id])
  comments       PostComment[]
  reactions      PostReaction[]
  reshares       PostReshare[]

  @@index([createdAt])
}

model PostReaction {
  id             String @id @default(cuid())
  postId         String
  userId         String
  kind           String
  createdAt      DateTime @default(now())

  post           Post @relation(fields: [postId], references: [id])
  user           User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model PostComment {
  id             String @id @default(cuid())
  postId         String
  userId         String
  body           String
  timestampSeconds Int?
  createdAt      DateTime @default(now())

  post           Post @relation(fields: [postId], references: [id])
  user           User @relation(fields: [userId], references: [id])

  @@index([postId, createdAt])
}

model PostReshare {
  id             String @id @default(cuid())
  postId         String
  userId         String
  targetGroupId  String?
  createdAt      DateTime @default(now())

  post           Post @relation(fields: [postId], references: [id])
  user           User @relation(fields: [userId], references: [id])

  @@index([postId, createdAt])
}

model ModerationFlag {
  id              String @id @default(cuid())
  chatMessageId   String @unique
  severity        ChatViolationSeverity
  reason          String
  aiLabel         String
  createdAt       DateTime @default(now())

  chatMessage     ChatMessage @relation(fields: [chatMessageId], references: [id])
}

model UserDisciplineState {
  id                String   @id @default(cuid())
  userId            String   @unique
  suspendedUntil    DateTime?
  isShadowBanned    Boolean  @default(false)
  isDeletedBanned   Boolean  @default(false)
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
}

model BannedIdentity {
  id                String   @id @default(cuid())
  phone             String?  @unique
  deviceId          String?  @unique
  reason            String
  bannedByAdminId   String
  createdAt         DateTime @default(now())
}

model MarketplaceApproval {
  id                String   @id @default(cuid())
  userId            String
  certificateTitle  String
  status            MarketplaceApprovalStatus @default(PENDING)
  reviewedByAdminId String?
  reviewedAt        DateTime?
  createdAt         DateTime @default(now())

  @@index([userId, status])
}

model TalentFeature {
  id                String   @id @default(cuid())
  userId            String   @unique
  isFeatured        Boolean  @default(false)
  updatedByAdminId  String
  updatedAt         DateTime @updatedAt
}

model AdModerationReview {
  id                String   @id @default(cuid())
  externalAdId      String   @unique
  targeting         String
  note              String?
  status            AdReviewStatus @default(PENDING)
  reviewedByAdminId String?
  reviewedAt        DateTime?
  createdAt         DateTime @default(now())
}

model AdminActionLog {
  id                String   @id @default(cuid())
  adminUserId       String
  action            String
  targetUserId      String?
  targetEntity      String
  reason            String?
  metadata          Json?
  createdAt         DateTime @default(now())

  adminUser         User     @relation("AdminActorActions", fields: [adminUserId], references: [id])

  @@index([createdAt])
  @@index([adminUserId, action])
}

model BlockRelation {
  id            String @id @default(cuid())
  blockerId     String
  blockedId     String
  reasonCode    BlockReasonCode?
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  unblockedAt   DateTime?

  blocker       User @relation("Blocker", fields: [blockerId], references: [id])
  blocked       User @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@index([blockedId, createdAt])
}

model MuteRelation {
  id            String @id @default(cuid())
  muterId       String
  mutedId       String
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  muter         User @relation("Muter", fields: [muterId], references: [id])
  muted         User @relation("Muted", fields: [mutedId], references: [id])

  @@unique([muterId, mutedId])
}

model UserReport {
  id            String @id @default(cuid())
  reporterId    String
  reportedId    String
  reasonCode    ReportReasonCode
  detail        String?
  createdAt     DateTime @default(now())

  reporter      User @relation("Reporter", fields: [reporterId], references: [id])
  reported      User @relation("Reported", fields: [reportedId], references: [id])

  @@index([reportedId, createdAt])
}

model HighBlockAlert {
  id                 String @id @default(cuid())
  targetUserId       String
  blockersLast24h    Int
  flaggedAt          DateTime @default(now())
  reviewed           Boolean @default(false)

  @@unique([targetUserId, flaggedAt])
  @@index([targetUserId, reviewed])
}

model SafetyMetadataFlag {
  id                 String @id @default(cuid())
  chatId             String
  flaggedUserId      String
  riskScore          Int
  conductCategory    FaithConductCategory
  summary            String
  source             String @default("ON_DEVICE_LLAMA4_SCOUT")
  createdAt          DateTime @default(now())

  flaggedUser        User @relation(fields: [flaggedUserId], references: [id])

  @@index([chatId, createdAt])
  @@index([riskScore])
}

model BreakGlassReportBundle {
  id                 String @id @default(cuid())
  trigger            BreakGlassTrigger
  chatId             String
  reporterUserId     String?
  reportedUserId     String
  conductCategory    FaithConductCategory
  riskScore          Int?
  messageFrankingProof String?
  localAiSummary     String?
  resolution         BreakGlassResolutionAction @default(PENDING)
  resolvedByAdminId  String?
  resolvedAt         DateTime?
  createdAt          DateTime @default(now())

  reporterUser       User? @relation("BundleReporter", fields: [reporterUserId], references: [id])
  evidenceMessages   BreakGlassEvidenceMessage[]

  @@index([chatId, createdAt])
  @@index([resolution, createdAt])
}

model BreakGlassEvidenceMessage {
  id                 String @id @default(cuid())
  bundleId           String
  senderUserId       String
  body               String
  createdAt          DateTime @default(now())

  bundle             BreakGlassReportBundle @relation(fields: [bundleId], references: [id])

  @@index([bundleId, createdAt])
}

model GatheringPlace {
  id             String @id @default(cuid())
  name           String
  country        String
  stateOrCity    String
  lga            String?
  latitude       Float
  longitude      Float
  geohash        String?
  isGlobal       Boolean @default(false)
  createdAt      DateTime @default(now())

  groups         GatheringGroup[]
  checkIns       GatheringCheckIn[]
}

model GatheringGroup {
  id               String @id @default(cuid())
  gatheringPlaceId String
  name             String
  level            GatheringLevel @default(LOCAL)
  category         GroupCategory @default(GENERAL)
  parentGroupId    String?
  adminUserId      String?
  isPrivate        Boolean @default(false)
  createdAt        DateTime @default(now())

  gatheringPlace   GatheringPlace @relation(fields: [gatheringPlaceId], references: [id])
  memberships      GatheringGroupMembership[]

  @@index([gatheringPlaceId, level])
}

model GatheringGroupMembership {
  id            String @id @default(cuid())
  userId        String
  groupId       String
  role          GroupMembershipRole @default(MEMBER)
  joinedAt      DateTime @default(now())

  user          User @relation(fields: [userId], references: [id])
  group         GatheringGroup @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

model GatheringCheckIn {
  id               String @id @default(cuid())
  userId           String
  gatheringPlaceId String
  checkedInAt      DateTime @default(now())

  user             User @relation(fields: [userId], references: [id])
  gatheringPlace   GatheringPlace @relation(fields: [gatheringPlaceId], references: [id])

  @@index([userId, checkedInAt])
}

model GroupMessageReadReceipt {
  id            String @id @default(cuid())
  messageId     String
  userId        String
  readAt        DateTime @default(now())

  message       ChatMessage @relation(fields: [messageId], references: [id])
  user          User @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}
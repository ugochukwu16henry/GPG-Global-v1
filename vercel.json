{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bash ./scripts/vercel-install.sh",
  "buildCommand": "bash ./scripts/vercel-build.sh",
  "outputDirectory": "build/web",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
